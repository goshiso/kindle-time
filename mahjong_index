<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>服务器跳转中...</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            background-color: #f5f5f5;
        }
        .container {
            text-align: center;
            padding: 20px;
            background: white;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        #status {
            color: #333;
            font-size: 18px;
        }
        .error {
            color: red !important;
        }
    </style>
</head>
<body>
    <div class="container">
        <h2 id="status">初始化跳转流程...</h2>
    </div>

    <script>
        async function startRedirectProcess() {
            const statusEl = document.getElementById('status');

            try {
                // 1. 获取 TF 服务器 IP
                statusEl.textContent = "1/3: 正在获取 TF 服务器 IP...";
                const tfResponse = await fetch('https://goshiso.github.io/kindle-time/text');
                
                if (!tfResponse.ok) {
                    throw new Error('无法访问 GitHub 获取 TF 服务器 IP');
                }
                
                let tfServerIp = await tfResponse.text();
                tfServerIp = tfServerIp.trim(); // 去除可能的多余空格或换行符
                
                // 确保 IP 包含 http:// 前缀
                if (!tfServerIp.startsWith('http')) {
                    tfServerIp = 'http://' + tfServerIp;
                }

                // 2. 获取主服务器 IP
                statusEl.textContent = "2/3: 正在连接 TF 服务器获取主节点...";
                // 假设接口返回的纯文本是主服务器 IP
                const mainResponse = await fetch(`${tfServerIp}/getIP`);
                
                if (!mainResponse.ok) {
                    throw new Error('无法从 TF 服务器获取主服务器 IP');
                }

                let mainServerIp = await mainResponse.text();
                mainServerIp = mainServerIp.trim();

                if (!mainServerIp.startsWith('http')) {
                    mainServerIp = 'http://' + mainServerIp;
                }

                // 3. 跳转到主服务器
                statusEl.textContent = "3/3: 获取成功，正在跳转...";
                
                // 确保路径拼接正确
                const targetUrl = mainServerIp.endsWith('/') ? 
                                 `${mainServerIp}index` : 
                                 `${mainServerIp}/index`;
                                 
                window.location.href = targetUrl;

            } catch (error) {
                console.error("跳转失败:", error);
                statusEl.textContent = `跳转失败: ${error.message}`;
                statusEl.className = "error";
            }
        }

        // 当页面加载完成后开始执行
        window.onload = startRedirectProcess;
    </script>
</body>
</html>
